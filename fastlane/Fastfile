# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  
  lane :beta do
    # Define API key for this lane
    api_key = app_store_connect_api_key(
      key_id: "6735D72L89",
      issuer_id: "69a6de97-1b94-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/ApiKey_6735D72L89.p8"),
      duration: 1200,
      in_house: false
    )

    increment_build_number(xcodeproj: "iSpend.xcodeproj")

    # Build and upload iOS
    gym(
      scheme: "iSpend",
      output_directory: "./build",
      output_name: "iSpend-iOS",
      clean: true,
      export_options: "./ExportOptions.plist",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/iSpend-iOS.ipa",
      skip_waiting_for_build_processing: true
    )

    # Build and upload Mac Catalyst
    gym(
      scheme: "iSpend",
      destination: "platform=macOS,variant=Mac Catalyst",
      output_directory: "./build",
      output_name: "iSpend-Mac",
      export_options: "./ExportOptions-mac.plist",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      pkg: "./build/iSpend-Mac.pkg",
      skip_waiting_for_build_processing: true
    )
  end
end

lane :release do
  capture_screenshots
  build_app
  upload_to_app_store       # Upload the screenshots and the binary to iTunes
end

lane  :bump do
        increment_build_number(xcodeproj: "iSpend.xcodeproj")
end

lane :upload do
  # Define API key for upload
  api_key = app_store_connect_api_key(
    key_id: "6735D72L89",
    issuer_id: "69a6de97-1b94-47e3-e053-5b8c7c11a4d1",
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/ApiKey_6735D72L89.p8"),
    duration: 1200,
    in_house: false
  )
  
  upload_to_testflight(
    api_key: api_key,
    ipa: "./build/iSpend.ipa",
    skip_waiting_for_build_processing: true
  )
end

lane :test_auth do
  # Test API key authentication
  api_key = app_store_connect_api_key(
    key_id: "6735D72L89",
    issuer_id: "69a6de97-1b94-47e3-e053-5b8c7c11a4d1",
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/ApiKey_6735D72L89.p8"),
    duration: 1200,
    in_house: false
  )
  
  # Try to get app information to test authentication
  begin
    get_app_store_connect_api_key_info(
      api_key: api_key
    )
    UI.success("API Key seems to be configured correctly")
  rescue => e
    UI.error("API Key test failed: #{e.message}")
  end
end

